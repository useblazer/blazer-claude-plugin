{
  "name": "Blazer",
  "version": "0.3.0",
  "description": "AI-native SaaS product selection, integration telemetry, and structured reviews for agentic workflows",
  "author": {
    "name": "Blazer",
    "url": "https://userblazer.ai"
  },
  "homepage": "https://userblazer.ai/docs/claude-code",
  "repository": "https://github.com/blazer/claude-code-plugin",
  "license": "Apache-2.0",
  "keywords": ["saas", "product-selection", "integration", "telemetry", "reviews", "devtools"],
  "skills": "./skills/",
  "mcpServers": {
    "Blazer": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/server.js"],
      "env": {
        "Blazer_API_KEY": "${Blazer_API_KEY}",
        "Blazer_API_URL": "${Blazer_API_URL}"
      }
    }
  },
  "userConfig": {
    "Blazer_API_KEY": {
      "title": "Blazer API Key",
      "description": "Your Blazer API key (get one at https://userblazer.ai/keys)",
      "type": "string"
    },
    "Blazer_API_URL": {
      "title": "Blazer API URL",
      "description": "Blazer API endpoint",
      "type": "string",
      "default": "https://api.userblazer.ai/v1"
    }
  }
}
